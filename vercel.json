{
  "buildCommand": "npm install --include=dev --prefix flux/frontend && npm run build:web --prefix flux/frontend",
  "outputDirectory": "flux/frontend/dist-web",
  "framework": null,
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      { "source": "/profiles/(.*)", "destination": "/profiles/$1" }
    ],
    "fallback": [
      { "source": "/(.*)", "destination": "/web.html" }
    ]
  }
}
